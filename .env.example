# ============================================================
# POS System environment
#
# Local dev:   copy to .env, set the two change-me secrets, done.
# VPS deploy:  paste these into Portainer's stack environment
#              variables and follow the PRODUCTION comments —
#              search for "PROD:" below.
# ============================================================

# ---- Application ----
# PROD: set APP_ENV=production (enables HSTS and release mode)
APP_ENV=development
APP_NAME=POS System
HTTP_PORT=9137

# Port the whole app is published on (the stack's nginx entrypoint).
# PROD: your reverse proxy (e.g. Nginx Proxy Manager) forwards the
# domain to this port; nothing else needs to be exposed.
WEB_PORT=7642

# Browser origins allowed to call the API (comma-separated).
# PROD: CORS_ORIGINS=https://pos.yourdomain.uk
CORS_ORIGINS=http://localhost:7642

# Public base URL used in emailed links (password reset, verification).
# Defaults to the FIRST entry of CORS_ORIGINS.
# PROD: APP_URL=https://pos.yourdomain.uk
# APP_URL=

# ---- PostgreSQL ----
DB_HOST=postgres
DB_PORT=5432
DB_USER=pos
DB_PASSWORD=change-me-strong-password
DB_NAME=pos
DB_SSLMODE=disable
DB_MAX_CONNS=20

# ---- Redis ----
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- MinIO (product/logo images) ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pos
MINIO_USE_SSL=false
# Where browsers load stored images from — must match how the app is reached.
# PROD: MINIO_PUBLIC_BASE_URL=https://pos.yourdomain.uk/storage
MINIO_PUBLIC_BASE_URL=http://localhost:7642/storage

# ---- JWT ----
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-generate-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ---- SMTP ----
# Dev default is the bundled Mailpit (view mail at http://localhost:9284).
# PROD: point at a real provider (e.g. Resend/Mailgun/SES SMTP creds)
#   SMTP_HOST=smtp.yourprovider.com
#   SMTP_PORT=587
#   SMTP_USER=...
#   SMTP_PASSWORD=...
#   SMTP_FROM=noreply@yourdomain.uk
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@pos.local
# Friendly sender name shown in inboxes ("POS System <noreply@...>")
SMTP_FROM_NAME=POS System

# --- Xendit subscription billing ---
# PROD: use your LIVE secret key (xnd_production_...) and set the SAME
# verification token here and in the Xendit dashboard webhook settings.
# Webhook URL to register in Xendit: https://<your-domain>/api/v1/webhooks/xendit
# Dev: test key (xnd_development_...) works for creating invoices; real
# callbacks can't reach localhost — simulate them with curl (docs/BILLING-PLAN.md).
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# First-boot auto-seed: admin (super admin only, default) | demo | off
SEED_ON_START=admin
# Password for ALL seeded accounts (super admin + demo)
SEED_PASSWORD=password123
