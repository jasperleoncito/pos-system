# ---- Application ----
APP_ENV=development
APP_NAME=POS System
HTTP_PORT=9137
CORS_ORIGINS=http://localhost:7642

# ---- PostgreSQL ----
DB_HOST=postgres
DB_PORT=5432
DB_USER=pos
DB_PASSWORD=change-me-strong-password
DB_NAME=pos
DB_SSLMODE=disable
DB_MAX_CONNS=20

# ---- Redis ----
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- MinIO ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change-me-access-key
MINIO_SECRET_KEY=change-me-secret-key
MINIO_BUCKET=pos
MINIO_USE_SSL=false
MINIO_PUBLIC_BASE_URL=http://localhost:7642/storage

# ---- JWT ----
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-generate-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ---- SMTP (Mailpit in dev) ----
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@pos.local
